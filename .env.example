# Required
ANTHROPIC_API_KEY=sk-ant-...
CONVEX_URL=http://convex:3210
HUB_BOOTSTRAP_KEY=your-generated-key
HUB_URL=https://hub.tarrantcountymakerspace.com
PORT=4000

# Telegram (optional — hub works without, but you lose visibility)
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_GROUP_ID=-100...

# Git operations (for repo-fixer)
GITHUB_PAT=ghp_...
REPO_URL=https://github.com/melvenac/A2A-Hub.git
REPO_PATH=/tmp/A2A-Hub

# LLM models (configurable per task — defaults to claude-sonnet-4-20250514)
CLASSIFIER_MODEL=claude-sonnet-4-20250514
REPO_FIXER_MODEL=claude-sonnet-4-20250514

# Tuning
CONFIDENCE_THRESHOLD=0.85
